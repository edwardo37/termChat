{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Compile and Run/Debug termChat",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "termChat task: Configure and build termChat",
            "program": "${workspaceFolder}/out/build/${config:termChat.platform}-${config:termChat.compiler}-${config:termChat.buildType}/termChat",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
                },
                {
                "description": "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
                }
            ]
        }
    ]
}